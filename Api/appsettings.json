{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReleaseGenerator": {
    "Ollama": {
      "BaseUrl": "http://localhost:11434",
      "Model": "llama3.2",
      "TimeoutSeconds": 120
    },
    "Languages": ["en", "fr"],
    "Formats": {
      "discord": {
        "ExampleTemplate": "🎉 **Version {version}** is out!\n\nSummary of changes:\n- Added: ...\n- Fixed: ...\n\nFull changelog: ..."
      },
      "email": {
        "ExampleTemplate": "Subject: Release {version}\n\nWe're pleased to announce version {version}.\n\nChanges:\n- ..."
      },
      "website": {
        "ExampleTemplate": "<h2>Release {version}</h2><p>Release date: {date}</p><ul><li>...</li></ul>"
      },
      "appstores": {
        "ExampleTemplate": "What's New in {version}:\n• ...\n• ..."
      }
    }
  }
}
